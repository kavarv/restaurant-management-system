{
  "info": {
    "_postman_id": "rms-v1-collection",
    "name": "Restaurant Management System API",
    "description": "Complete API collection for the RMS Spring Boot application.\n\n**Setup:**\n1. Import this collection and the `RMS_Environment.json` environment.\n2. Set `{{baseUrl}}` to `http://localhost:8080`.\n3. Run the **Login** request first — the test script saves `JSESSIONID` and `csrfToken` automatically.\n4. All subsequent requests inherit those variables.\n\n**CSRF:** Every mutating request (POST/PUT/PATCH/DELETE) includes `X-CSRF-TOKEN: {{csrfToken}}`. Call `GET /api/v1/auth/csrf` to refresh if the token expires.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost:8080", "type": "string" },
    { "key": "sessionId",  "value": "",                      "type": "string" },
    { "key": "csrfToken",  "value": "",                      "type": "string" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "GET CSRF Token",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var json = pm.response.json();",
              "if (json.token) { pm.collectionVariables.set('csrfToken', json.token); }",
              "pm.test('CSRF token present', () => pm.expect(json.token || json.message).to.exist);"
            ]}
          }],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/csrf", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","csrf"] }
          },
          "response": [{
            "name": "200 OK",
            "status": "OK", "code": 200,
            "body": "{\n  \"token\": \"abc123xyz\",\n  \"headerName\": \"X-CSRF-TOKEN\",\n  \"paramName\": \"_csrf\"\n}"
          }]
        },
        {
          "name": "Login",
          "event": [{
            "listen": "prerequest",
            "script": { "exec": [
              "// Fetch a fresh CSRF token before logging in",
              "pm.sendRequest({ url: pm.collectionVariables.get('baseUrl') + '/api/v1/auth/csrf', method: 'GET' },",
              "  function(err, res) {",
              "    var json = res.json();",
              "    if (json.token) pm.collectionVariables.set('csrfToken', json.token);",
              "  }",
              ");"
            ]}
          },{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('username present', () => pm.expect(pm.response.json().username).to.exist);",
              "// Save JSESSIONID from Set-Cookie header",
              "var cookie = pm.response.headers.get('Set-Cookie');",
              "if (cookie) {",
              "  var match = cookie.match(/JSESSIONID=([^;]+)/);",
              "  if (match) pm.collectionVariables.set('sessionId', match[1]);",
              "}",
              "// Also grab from cookie jar",
              "var jsessionid = pm.cookies.get('JSESSIONID');",
              "if (jsessionid) pm.collectionVariables.set('sessionId', jsessionid);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "X-CSRF-TOKEN", "value": "{{csrfToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"] }
          },
          "response": [{
            "name": "200 OK",
            "status": "OK", "code": 200,
            "body": "{\n  \"username\": \"admin\",\n  \"tokenType\": \"Session\"\n}"
          }]
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "X-CSRF-TOKEN", "value": "{{csrfToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"newwaiter\",\n  \"email\": \"newwaiter@restaurant.com\",\n  \"password\": \"Waiter@456\",\n  \"role\": \"WAITER\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","register"] }
          },
          "response": [{
            "name": "201 Created",
            "status": "Created", "code": 201,
            "body": "{\n  \"id\": 10,\n  \"username\": \"newwaiter\",\n  \"email\": \"newwaiter@restaurant.com\",\n  \"role\": \"WAITER\"\n}"
          }]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Cookie",        "value": "JSESSIONID={{sessionId}}" },
              { "key": "X-CSRF-TOKEN", "value": "{{csrfToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","logout"] }
          },
          "response": [{ "name": "204 No Content", "status": "No Content", "code": 204, "body": "" }]
        }
      ]
    },

